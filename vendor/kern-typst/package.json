{
  "name": "kern-typst",
  "version": "0.1.0",
  "description": "Compile Typst articles to HTML with kern-rendered math",
  "license": "MIT",
  "author": "Tejas Prabhune",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "preamble",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "kern-typ": "^0.2.0",
    "unified": "^11.0.5",
    "rehype-parse": "^9.0.0",
    "rehype-stringify": "^10.0.0",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-html": "^9.0.3",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/hast": "^3.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
