---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  minimalNav?: boolean;
}

const { title, description = 'An open-source curriculum, recordings index, files archive, and K reference for college parliamentary debate.', minimalNav = false } = Astro.props;

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/curriculum', label: 'Curriculum' },
  { href: '/k', label: 'Ks' },
  { href: '/recordings', label: 'Recordings' },
  { href: '/files', label: 'Files' },
  { href: '/playbooks', label: 'Playbooks' },
  { href: '/lectures', label: 'Lectures' },
];

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + '/');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="https://use.typekit.net/ten2ahn.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-paper/95 backdrop-blur-sm border-b border-ink/10">
      <nav aria-label="Main navigation" class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        {!minimalNav && (
          <a
            href="/"
            class="font-display italic text-heading text-xl leading-none hover:text-accent transition-colors"
            aria-current={pathname === '/' ? 'page' : undefined}
          >
            the golden turn
          </a>
        )}

        {minimalNav && <span />}

        <div class={`hidden md:flex items-center gap-6`}>
          {!minimalNav && navLinks.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
              class={`text-sm font-sans transition-colors ${isActive(href) ? 'text-ink/90' : 'text-ink/60 hover:text-accent'}`}
            >
              {label}
            </a>
          ))}
          <button
            id="search-trigger"
            type="button"
            class={`text-sm font-sans transition-colors ${isActive('/search') ? 'text-ink/90' : 'text-ink/60 hover:text-accent'}`}
          >
            Search
          </button>
        </div>

        <div class="flex items-center gap-3 md:hidden">
          <button
            id="search-trigger"
            type="button"
            class="text-sm font-sans text-ink/60 hover:text-accent transition-colors"
          >
            Search
          </button>
          {!minimalNav && (
            <button
              id="mobile-menu-toggle"
              type="button"
              aria-label="Open navigation menu"
              class="text-ink/60 hover:text-accent transition-colors p-1"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="2" y1="5" x2="18" y2="5" />
                <line x1="2" y1="10" x2="18" y2="10" />
                <line x1="2" y1="15" x2="18" y2="15" />
              </svg>
            </button>
          )}
        </div>
      </nav>

      {!minimalNav && (
        <div
          id="mobile-menu"
          class="hidden md:hidden border-t border-ink/10 bg-paper"
        >
          <nav aria-label="Mobile navigation" class="px-6 py-4 flex flex-col gap-4">
            {navLinks.map(({ href, label }) => (
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                class={`text-sm font-sans transition-colors ${isActive(href) ? 'text-ink/90' : 'text-ink/60 hover:text-accent'}`}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
      )}
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 pt-8">
      <div class="max-w-6xl mx-auto px-6 pb-10 flex items-center justify-between">
        <span class="font-display italic text-heading/50 text-sm">the golden turn</span>
        <a href="/contribute" class="font-sans text-sm text-ink/40 hover:text-ink transition-colors">contribute</a>
      </div>
    </footer>
  </body>
</html>

<script>
  import { algoliasearch } from 'algoliasearch';

  const APP_ID = import.meta.env.PUBLIC_ALGOLIA_APP_ID as string;
  const SEARCH_KEY = import.meta.env.PUBLIC_ALGOLIA_SEARCH_KEY as string;
  const CONTENT_INDEX = 'goldenturn_content';

  const algolia = algoliasearch(APP_ID, SEARCH_KEY);

  let overlayEl: HTMLElement | null = null;
  let overlayInput: HTMLInputElement | null = null;
  let quickResultsEl: HTMLElement | null = null;
  let overlayDebounce: ReturnType<typeof setTimeout> | undefined;
  let activeItemIndex = -1;
  let quickItems: HTMLAnchorElement[] = [];

  function buildOverlay() {
    const el = document.createElement('div');
    el.id = 'search-overlay';
    el.setAttribute('role', 'dialog');
    el.setAttribute('aria-modal', 'true');
    el.setAttribute('aria-label', 'Quick search');
    el.innerHTML = `
      <div
        id="search-backdrop"
        class="fixed inset-0 z-[100] bg-ink/20 backdrop-blur-sm flex items-start justify-center pt-24 px-4"
      >
        <div class="w-full max-w-xl bg-paper border border-ink/10 rounded-xl shadow-xl p-6">
          <input
            id="overlay-input"
            type="search"
            placeholder="Search everything..."
            autocomplete="off"
            class="w-full border border-ink/15 rounded-lg px-4 py-2.5 text-ink placeholder-ink/40 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent text-sm font-sans"
          />
          <div id="overlay-quick-results" class="mt-3 space-y-1"></div>
          <div id="overlay-see-all" class="hidden mt-3 pt-3 border-t border-ink/10">
            <a
              id="overlay-see-all-link"
              href="/search"
              class="text-sm font-sans text-heading hover:underline"
            >See all results &rarr;</a>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(el);

    overlayEl = el;
    overlayInput = el.querySelector('#overlay-input');
    quickResultsEl = el.querySelector('#overlay-quick-results');

    el.querySelector('#search-backdrop')!.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeOverlay();
    });

    overlayInput!.addEventListener('keydown', handleOverlayKeydown);
    overlayInput!.addEventListener('input', () => {
      clearTimeout(overlayDebounce);
      overlayDebounce = setTimeout(() => fetchQuickResults(overlayInput!.value.trim()), 200);
    });
  }

  function openOverlay() {
    if (!overlayEl) buildOverlay();
    overlayEl!.classList.remove('hidden');
    overlayInput!.value = '';
    quickResultsEl!.innerHTML = '';
    (overlayEl!.querySelector('#overlay-see-all') as HTMLElement).classList.add('hidden');
    activeItemIndex = -1;
    quickItems = [];
    setTimeout(() => overlayInput!.focus(), 10);
  }

  function closeOverlay() {
    overlayEl?.classList.add('hidden');
    activeItemIndex = -1;
    quickItems = [];
  }

  function handleOverlayKeydown(e: KeyboardEvent) {
    if (e.key === 'Escape') {
      closeOverlay();
      return;
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeItemIndex = Math.min(activeItemIndex + 1, quickItems.length - 1);
      updateActiveItem();
      return;
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeItemIndex = Math.max(activeItemIndex - 1, -1);
      updateActiveItem();
      return;
    }
    if (e.key === 'Enter' && activeItemIndex >= 0 && quickItems[activeItemIndex]) {
      quickItems[activeItemIndex].click();
      return;
    }
    if (e.key === 'Enter') {
      const q = overlayInput!.value.trim();
      if (q) window.location.href = `/search?q=${encodeURIComponent(q)}`;
    }
  }

  function updateActiveItem() {
    quickItems.forEach((item, i) => {
      item.classList.toggle('bg-ink/5', i === activeItemIndex);
    });
    if (activeItemIndex >= 0) quickItems[activeItemIndex]?.scrollIntoView({ block: 'nearest' });
  }

  const TYPE_LABELS: Record<string, string> = {
    curriculum: 'Curriculum',
    k: 'K Reference',
    file: 'File',
    playbook: 'Playbook',
  };

  function escapeHtml(str: string): string {
    return (str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function fetchQuickResults(query: string) {
    if (!query) {
      quickResultsEl!.innerHTML = '';
      (overlayEl!.querySelector('#overlay-see-all') as HTMLElement).classList.add('hidden');
      return;
    }

    const hits = await algolia
      .searchSingleIndex({ indexName: CONTENT_INDEX, searchParams: { query, hitsPerPage: 10 } })
      .then(r => r.hits as Record<string, unknown>[])
      .catch(() => []);

    quickResultsEl!.innerHTML = '';
    activeItemIndex = -1;
    quickItems = [];

    const shown = hits.slice(0, 5);

    for (const hit of shown) {
      const type = (hit['type'] as string) ?? '';
      const title = ((hit['title'] ?? hit['name']) as string) ?? '';
      const url = (hit['url'] as string) ?? '#';
      const desc = (hit['description'] as string) ?? '';
      const label = TYPE_LABELS[type] ?? type;

      const a = document.createElement('a');
      a.href = url;
      a.className = 'block px-3 py-2 rounded-lg transition-colors hover:bg-ink/5';
      a.innerHTML = `
        <p class="text-xs font-sans uppercase tracking-widest text-ink/30 mb-0.5">${escapeHtml(label)}</p>
        <p class="text-sm text-heading font-sans font-medium">${escapeHtml(title)}</p>
        ${desc ? `<p class="text-xs text-ink/50 truncate font-sans">${escapeHtml(desc)}</p>` : ''}
      `;
      a.addEventListener('click', closeOverlay);
      quickResultsEl!.appendChild(a);
      quickItems.push(a);
    }

    const seeAllContainer = overlayEl!.querySelector('#overlay-see-all') as HTMLElement;
    const seeAllLink = overlayEl!.querySelector('#overlay-see-all-link') as HTMLAnchorElement;
    seeAllLink.href = `/search?q=${encodeURIComponent(query)}`;
    seeAllContainer.classList.toggle('hidden', shown.length === 0);
  }

  document.querySelectorAll<HTMLButtonElement>('#search-trigger').forEach(btn => {
    btn.addEventListener('click', openOverlay);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      openOverlay();
    }
    if (e.key === 'Escape' && overlayEl && !overlayEl.classList.contains('hidden')) {
      closeOverlay();
    }
  });

  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
