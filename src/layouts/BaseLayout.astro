---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  minimalNav?: boolean;
  noFooter?: boolean;
}

const { title, description = 'An open-source curriculum, recordings index, files archive, and K reference for college parliamentary debate.', minimalNav = false, noFooter = false } = Astro.props;

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/curriculum', label: 'Curriculum' },
  { href: '/k', label: 'Ks' },
  { href: '/recordings', label: 'Recordings' },
  { href: '/files', label: 'Files' },
  { href: '/playbooks', label: 'Playbooks' },
  { href: '/lectures', label: 'Lectures' },
];

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + '/');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="https://use.typekit.net/ten2ahn.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-paper/95 backdrop-blur-sm border-b border-ink/10">
      <nav aria-label="Main navigation" class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        {!minimalNav && (
          <a
            href="/"
            class="font-sans text-xs tracking-widest text-ink/30 hover:text-ink/60 transition-colors uppercase"
            aria-current={pathname === '/' ? 'page' : undefined}
          >
            gt
          </a>
        )}

        {minimalNav && <span />}

        <div class={`hidden md:flex items-center gap-7`}>
          {!minimalNav && navLinks.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
              class={`text-sm font-sans tracking-wide transition-colors ${isActive(href) ? 'text-ink underline underline-offset-4 decoration-2 decoration-accent' : 'text-ink/50 hover:text-ink'}`}
            >
              {label}
            </a>
          ))}
          <a
            href="/search"
            aria-current={isActive('/search') ? 'page' : undefined}
            class={`text-sm font-sans tracking-wide transition-colors ${isActive('/search') ? 'text-ink underline underline-offset-4 decoration-2 decoration-accent' : 'text-ink/50 hover:text-ink'}`}
          >
            Search
          </a>
        </div>

        <div class="flex items-center gap-3 md:hidden">
          <a
            href="/search"
            class="text-sm font-sans text-ink/60 hover:text-accent transition-colors"
          >
            Search
          </a>
          {!minimalNav && (
            <button
              id="mobile-menu-toggle"
              type="button"
              aria-label="Open navigation menu"
              class="text-ink/60 hover:text-accent transition-colors p-1"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="2" y1="5" x2="18" y2="5" />
                <line x1="2" y1="10" x2="18" y2="10" />
                <line x1="2" y1="15" x2="18" y2="15" />
              </svg>
            </button>
          )}
        </div>
      </nav>

      {!minimalNav && (
        <div
          id="mobile-menu"
          class="hidden md:hidden border-t border-ink/10 bg-paper"
        >
          <nav aria-label="Mobile navigation" class="px-6 py-4 flex flex-col gap-4">
            {navLinks.map(({ href, label }) => (
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                class={`text-sm font-sans transition-colors ${isActive(href) ? 'text-ink/90' : 'text-ink/60 hover:text-accent'}`}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
      )}
    </header>

    <main>
      <slot />
    </main>

    {!noFooter && (
      <footer class="mt-24 pt-8">
        <div class="max-w-6xl mx-auto px-6 pb-10 flex items-center justify-between">
          <span class="font-sans text-xs tracking-widest text-ink/25 uppercase">gt</span>
          <a href="/contribute" class="font-sans text-sm text-ink/40 hover:text-ink transition-colors">contribute</a>
        </div>
      </footer>
    )}
  </body>
</html>

<script>
  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Keyboard shortcut: press / to jump to search page
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      window.location.href = '/search';
    }
  });

</script>
