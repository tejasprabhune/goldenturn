---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'curriculum'>;
  allArticles: CollectionEntry<'curriculum'>[];
  Content: any;
}

const { article, allArticles, Content } = Astro.props;

const SECTION_ORDER = ['goals'] as const;
const SECTION_LABELS: Record<string, string> = {
  goals: 'Goals',
};

function toTitleCase(str: string) {
  return str.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const grouped = SECTION_ORDER.reduce<Record<string, CollectionEntry<'curriculum'>[]>>((acc, section) => {
  acc[section] = allArticles
    .filter(a => a.data.section === section)
    .sort((a, b) => a.data.order - b.data.order);
  return acc;
}, {} as Record<string, CollectionEntry<'curriculum'>[]>);

function articleHref(entry: CollectionEntry<'curriculum'>) {
  const parts = entry.id.replace(/\.(mdx?|typ)$/, '').split('/');
  const section = parts[0];
  const slug = parts.slice(1).join('/');
  return `/curriculum/${section}/${slug}`;
}

const currentHref = articleHref(article);

const sectionLabel = SECTION_LABELS[article.data.section] ?? article.data.section;

const relatedArticles = article.data.related_articles
  .map(slug => allArticles.find(a => a.id.replace(/\.(mdx?|typ)$/, '') === slug))
  .filter((a): a is CollectionEntry<'curriculum'> => !!a);

const hasRelated =
  relatedArticles.length > 0 ||
  article.data.related_ks.length > 0 ||
  article.data.related_recordings_tags.length > 0 ||
  article.data.related_files.length > 0;

---

<BaseLayout title={`${article.data.title} | Curriculum | the golden turn`}>
  <div class="max-w-6xl mx-auto px-6">
    <div class="lg:grid lg:gap-12" style="grid-template-columns: 220px 1fr">
      <aside class="hidden lg:block">
        <div class="sticky top-20 h-[calc(100vh-5rem)] overflow-y-auto pb-8 pr-2">
          <a href="/curriculum" class="font-display italic text-heading text-base block mb-6 hover:text-accent transition-colors">
            Curriculum
          </a>
          <nav aria-label="Article navigation">
            {SECTION_ORDER.map(section => {
              const articles = grouped[section];
              if (!articles || articles.length === 0) return null;
              return (
                <div class="mb-5">
                  <p class="font-sans uppercase tracking-widest text-ink/30 mb-2" style="font-size: 0.65rem;">
                    {SECTION_LABELS[section]}
                  </p>
                  <ul class="space-y-1">
                    {articles.map(entry => {
                      const href = articleHref(entry);
                      const isCurrent = href === currentHref;
                      return (
                        <li>
                          <a
                            href={href}
                            aria-current={isCurrent ? 'page' : undefined}
                            class={`block font-sans py-0.5 transition-colors ${isCurrent ? 'text-heading font-medium' : 'text-ink/50 hover:text-ink/90'}`}
                            style="font-size: 0.8125rem;"
                          >
                            {entry.data.title}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              );
            })}
          </nav>
        </div>
      </aside>

      <main class="py-14 min-w-0">
        <nav aria-label="Breadcrumb" class="flex items-center gap-1 font-sans text-ink/40 mb-4 flex-wrap" style="font-size: 0.75rem;">
          <a href="/curriculum" class="hover:text-ink transition-colors">Curriculum</a>
          <span>/</span>
          <a href={`/curriculum#${article.data.section}`} class="hover:text-ink transition-colors">{sectionLabel}</a>
          <span>/</span>
          <span class="text-ink/60" aria-current="page">{article.data.title}</span>
        </nav>

        <div class="lg:hidden mb-6">
          <button
            id="toc-toggle"
            type="button"
            class="font-sans text-sm border border-ink/20 rounded px-4 py-2 text-ink/70 hover:border-ink/40 hover:text-ink transition-colors"
          >
            Contents
          </button>
          <div id="toc-drawer" class="hidden mt-3 border border-ink/10 rounded-lg p-4">
            <nav aria-label="Article navigation">
              {SECTION_ORDER.map(section => {
                const articles = grouped[section];
                if (!articles || articles.length === 0) return null;
                return (
                  <div class="mb-4">
                    <p class="font-sans uppercase tracking-widest text-ink/30 mb-1" style="font-size: 0.65rem;">
                      {SECTION_LABELS[section]}
                    </p>
                    <ul class="space-y-1">
                      {articles.map(entry => {
                        const href = articleHref(entry);
                        const isCurrent = href === currentHref;
                        return (
                          <li>
                            <a
                              href={href}
                              aria-current={isCurrent ? 'page' : undefined}
                              class={`block font-sans py-0.5 transition-colors ${isCurrent ? 'text-heading font-medium' : 'text-ink/50 hover:text-ink/90'}`}
                              style="font-size: 0.8125rem;"
                            >
                              {entry.data.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                );
              })}
            </nav>
          </div>
        </div>

        <h1 class="font-display italic text-heading text-4xl sm:text-5xl leading-tight mb-10">
          {article.data.title}
        </h1>

        <div class="prose">
          <Content />
        </div>

        {hasRelated && (
          <section class="mt-16 pt-8 border-t border-ink/10">
            <p class="font-sans uppercase tracking-widest text-ink/30 mb-6" style="font-size: 0.75rem;">Related</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {relatedArticles.length > 0 && (
                <div>
                  <p class="font-sans uppercase tracking-widest text-ink/30 mb-3" style="font-size: 0.65rem;">Articles</p>
                  <ul class="space-y-2">
                    {relatedArticles.map(a => (
                      <li>
                        <a href={articleHref(a)} class="font-sans text-sm text-heading hover:underline transition-colors">
                          {a.data.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {article.data.related_ks.length > 0 && (
                <div>
                  <p class="font-sans uppercase tracking-widest text-ink/30 mb-3" style="font-size: 0.65rem;">Ks</p>
                  <ul class="space-y-2">
                    {article.data.related_ks.map(slug => (
                      <li>
                        <a href={`/k/${slug}`} class="font-sans text-sm text-heading hover:underline transition-colors">
                          {toTitleCase(slug)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {article.data.related_recordings_tags.length > 0 && (
                <div>
                  <p class="font-sans uppercase tracking-widest text-ink/30 mb-3" style="font-size: 0.65rem;">Recordings</p>
                  <ul class="space-y-2">
                    {article.data.related_recordings_tags.map(tag => (
                      <li>
                        <a href={`/recordings?tag=${encodeURIComponent(tag)}`} class="font-sans text-sm text-heading hover:underline transition-colors">
                          {tag}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {article.data.related_files.length > 0 && (
                <div>
                  <p class="font-sans uppercase tracking-widest text-ink/30 mb-3" style="font-size: 0.65rem;">Files</p>
                  <ul class="space-y-2">
                    {article.data.related_files.map(slug => (
                      <li>
                        <a href={`/files/${slug}`} class="font-sans text-sm text-heading hover:underline transition-colors">
                          {toTitleCase(slug)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>
        )}
      </main>
    </div>
  </div>

  <script>
    const tocToggle = document.getElementById('toc-toggle');
    const tocDrawer = document.getElementById('toc-drawer');
    if (tocToggle && tocDrawer) {
      tocToggle.addEventListener('click', () => {
        tocDrawer.classList.toggle('hidden');
      });
    }
  </script>
</BaseLayout>
