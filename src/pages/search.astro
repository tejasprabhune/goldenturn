---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search | the golden turn">
  <div class="max-w-3xl mx-auto px-6 pt-12 pb-24">
    <h1 class="font-display italic text-heading text-4xl mb-8">Search</h1>

    <input
      id="search-input"
      type="search"
      placeholder="Search everything..."
      autocomplete="off"
      autofocus
      class="w-full border border-ink/20 rounded-lg bg-white px-4 py-3 font-sans text-sm text-ink placeholder:text-ink/35 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-transparent mb-8"
    />

    <p id="results-count" class="text-xs font-sans text-ink/35 mb-6 hidden"></p>
    <div id="results"></div>

    <p id="empty-state" class="font-sans text-sm text-ink/40">
      Start typing to search across curriculum, recordings, Ks, files, and playbooks.
    </p>
  </div>
</BaseLayout>

<script>
  import { algoliasearch } from 'algoliasearch';

  const APP_ID = import.meta.env.PUBLIC_ALGOLIA_APP_ID as string;
  const SEARCH_KEY = import.meta.env.PUBLIC_ALGOLIA_SEARCH_KEY as string;

  const client = algoliasearch(APP_ID, SEARCH_KEY);

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('results') as HTMLDivElement;
  const resultsCount = document.getElementById('results-count') as HTMLParagraphElement;
  const emptyState = document.getElementById('empty-state') as HTMLParagraphElement;

  let debounceTimer: ReturnType<typeof setTimeout> | undefined;
  let focusedIndex = -1;
  let allLinks: HTMLAnchorElement[] = [];

  const GROUP_ORDER = ['curriculum', 'k', 'recording', 'file', 'playbook', 'lecture'];
  const GROUP_LABELS: Record<string, string> = {
    curriculum: 'Curriculum',
    k: 'K Reference',
    recording: 'Recordings',
    file: 'Files',
    playbook: 'Playbooks',
    lecture: 'Lectures',
  };

  function escapeHtml(str: string): string {
    return (str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  interface Hit {
    objectID: string;
    type?: string;
    title?: string;
    name?: string;
    url?: string;
    link?: string;
    description?: string;
    resolution?: string;
    _isRecording?: boolean;
  }

  async function runSearch(query: string) {
    if (!query.trim()) {
      resultsEl.innerHTML = '';
      resultsCount.classList.add('hidden');
      emptyState.classList.remove('hidden');
      focusedIndex = -1;
      allLinks = [];
      return;
    }

    emptyState.classList.add('hidden');

    const [contentHits, recordingHits] = await Promise.all([
      client
        .searchSingleIndex({ indexName: 'goldenturn_content', searchParams: { query, hitsPerPage: 40 } })
        .then(r => r.hits as Hit[])
        .catch(() => [] as Hit[]),
      client
        .searchSingleIndex({ indexName: 'all_rounds', searchParams: { query, hitsPerPage: 15 } })
        .then(r => (r.hits as Hit[]).map(h => ({ ...h, type: 'recording', _isRecording: true })))
        .catch(() => [] as Hit[]),
    ]);

    const all = [...contentHits, ...recordingHits];
    const total = all.length;

    // Group by type
    const groups: Record<string, Hit[]> = {};
    for (const hit of all) {
      const type = hit.type ?? 'other';
      if (!groups[type]) groups[type] = [];
      groups[type].push(hit);
    }

    resultsCount.textContent = `${total} result${total === 1 ? '' : 's'}`;
    resultsCount.classList.toggle('hidden', total === 0);

    resultsEl.innerHTML = '';
    focusedIndex = -1;
    allLinks = [];

    const orderedTypes = [
      ...GROUP_ORDER.filter(t => groups[t]?.length),
      ...Object.keys(groups).filter(t => !GROUP_ORDER.includes(t) && groups[t]?.length),
    ];

    if (total === 0) {
      resultsEl.innerHTML = `<p class="font-sans text-sm text-ink/40">No results for "${escapeHtml(query)}".</p>`;
      return;
    }

    for (const type of orderedTypes) {
      const hits = groups[type];
      const label = GROUP_LABELS[type] ?? type;

      const section = document.createElement('div');
      section.className = 'mb-8';
      section.innerHTML = `<p class="font-sans text-xs uppercase tracking-widest text-ink/30 mb-3">${escapeHtml(label)}</p>`;

      for (const hit of hits) {
        const isRecording = hit._isRecording;
        const title = (hit.title ?? hit.name ?? '') as string;
        const url = isRecording ? (hit.link ?? '#') : (hit.url ?? '#');
        const desc = isRecording ? (hit.resolution ?? '') : (hit.description ?? '');
        const external = isRecording;

        const a = document.createElement('a');
        a.href = escapeHtml(url);
        if (external) {
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
        }
        a.className = 'result-link flex flex-col px-4 py-3 -mx-4 rounded-lg hover:bg-ink/4 transition-colors';
        a.setAttribute('data-index', String(allLinks.length));
        a.innerHTML = `
          <span class="font-sans font-medium text-heading text-sm leading-snug">${escapeHtml(title)}</span>
          ${desc ? `<span class="font-sans text-ink/50 text-xs mt-0.5 line-clamp-1">${escapeHtml(desc)}</span>` : ''}
        `;
        section.appendChild(a);
        allLinks.push(a);
      }

      resultsEl.appendChild(section);
    }
  }

  // Keyboard navigation through results
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      focusedIndex = Math.min(focusedIndex + 1, allLinks.length - 1);
      updateFocus();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      focusedIndex = Math.max(focusedIndex - 1, -1);
      updateFocus();
    } else if (e.key === 'Enter' && focusedIndex >= 0 && allLinks[focusedIndex]) {
      allLinks[focusedIndex].click();
    }
  });

  function updateFocus() {
    allLinks.forEach((a, i) => {
      a.classList.toggle('bg-ink/5', i === focusedIndex);
    });
    if (focusedIndex >= 0) allLinks[focusedIndex]?.scrollIntoView({ block: 'nearest' });
  }

  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => runSearch(searchInput.value.trim()), 150);
  });

  // Pre-fill from ?q= param
  const q = new URLSearchParams(window.location.search).get('q') ?? '';
  if (q) {
    searchInput.value = q;
    runSearch(q);
  }
</script>
