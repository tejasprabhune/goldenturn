---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const SECTION_ORDER = ['goals'] as const;
const SECTION_LABELS: Record<string, string> = {
  goals: 'Goals',
};

const articles = await getCollection('curriculum', ({ data }) => !data.draft);

const grouped = SECTION_ORDER.reduce<Record<string, CollectionEntry<'curriculum'>[]>>((acc, section) => {
  acc[section] = articles
    .filter(a => a.data.section === section)
    .sort((a, b) => a.data.order - b.data.order);
  return acc;
}, {} as Record<string, CollectionEntry<'curriculum'>[]>);

function articleHref(entry: CollectionEntry<'curriculum'>) {
  const parts = entry.id.replace(/\.(mdx?|typ)$/, '').split('/');
  const section = parts[0];
  const slug = parts.slice(1).join('/');
  return `/curriculum/${section}/${slug}`;
}
---

<BaseLayout
  title="Curriculum | the golden turn"
  description="A complete guide to college parliamentary debate, from first principles to advanced theory."
>
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <h1 class="font-display italic text-heading text-5xl sm:text-6xl leading-tight mb-4">
      Curriculum
    </h1>
    <p class="font-body text-ink/60 text-base max-w-xl leading-relaxed mb-16">
      A complete guide to college parliamentary debate, from first principles to advanced theory.
    </p>

    <div class="space-y-14">
      {SECTION_ORDER.map(section => {
        const sectionArticles = grouped[section];
        if (!sectionArticles || sectionArticles.length === 0) return null;
        return (
          <section id={section}>
            <p class="font-sans uppercase tracking-widest text-ink/30 mb-4 pb-3 border-b border-ink/10" style="font-size: 0.75rem;">
              {SECTION_LABELS[section]}
            </p>
            <ul class="space-y-3">
              {sectionArticles.map(entry => (
                <li>
                  <a
                    href={articleHref(entry)}
                    class="flex items-baseline gap-3 group"
                  >
                    <span class="text-ink/30 font-mono shrink-0 text-right" style="font-size: 0.75rem; width: 1.5rem;">
                      {String(entry.data.order).padStart(2, '0')}
                    </span>
                    <span class="font-body text-ink group-hover:underline decoration-accent underline-offset-2 transition-colors">
                      {entry.data.title}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>
