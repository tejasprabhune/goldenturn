---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const files = await getCollection('files');
const isEmpty = files.length === 0;

const TYPE_OPTIONS = ['All', 'Case', 'Brief', 'Scaffold', 'Block'];
---

<BaseLayout
  title="Files | the golden turn"
  description="Cases, briefs, blocks, and scaffolds for parliamentary debate."
>
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-24">
    <h1 class="font-display italic text-heading text-5xl sm:text-6xl leading-tight mb-4">
      Files
    </h1>
    <p class="text-ink/60 text-lg max-w-2xl leading-relaxed mb-10">
      Cases, briefs, blocks, and scaffolds for parliamentary debate.
    </p>

    <div class="flex flex-wrap gap-3 mb-8 items-center">
      <div class="flex gap-1">
        {TYPE_OPTIONS.map(opt => (
          <button
            class="type-btn text-sm font-body px-3 py-1.5 rounded border border-ink/20 text-ink/60 hover:border-accent hover:text-accent transition-colors"
            data-type={opt.toLowerCase()}
          >
            {opt}
          </button>
        ))}
      </div>
      <input
        id="file-filter"
        type="search"
        placeholder="Search files..."
        class="border border-ink/20 rounded px-3 py-1.5 text-sm font-body bg-paper text-ink placeholder:text-ink/40 focus:outline-none focus:border-accent w-56"
      />
    </div>

    {isEmpty ? (
      <p class="text-ink/50 text-base">
        No files yet. Check back soon, or{' '}
        <a href="/contribute" class="text-accent hover:underline">contribute a file</a>.
      </p>
    ) : (
      <ul id="file-list" class="space-y-4">
        {files.map(entry => {
          const slug = entry.id.replace(/\.mdx?$/, '');
          return (
            <li class="file-item" data-type={entry.data.type} data-title={entry.data.title.toLowerCase()}>
              <a
                href={`/files/${slug}`}
                class="flex items-baseline gap-3 group hover:text-accent transition-colors"
              >
                <span class="text-xs font-mono bg-accent-soft/30 text-ink/50 rounded px-1.5 py-0.5 shrink-0">
                  {entry.data.type}
                </span>
                <span class="font-body text-ink group-hover:text-accent transition-colors">
                  {entry.data.title}
                </span>
                {entry.data.author && (
                  <span class="text-sm text-ink/40 ml-auto shrink-0">{entry.data.author}</span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>
</BaseLayout>

<script>
  const typeButtons = document.querySelectorAll<HTMLButtonElement>('.type-btn');
  const filterInput = document.getElementById('file-filter') as HTMLInputElement | null;
  const items = document.querySelectorAll<HTMLLIElement>('.file-item');

  let activeType = 'all';

  typeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      activeType = btn.dataset.type ?? 'all';
      typeButtons.forEach(b => b.classList.toggle('border-accent', b.dataset.type === activeType));
      typeButtons.forEach(b => b.classList.toggle('text-accent', b.dataset.type === activeType));
      applyFilters();
    });
  });

  filterInput?.addEventListener('input', applyFilters);

  function applyFilters() {
    const query = filterInput?.value.trim().toLowerCase() ?? '';
    items.forEach(item => {
      const matchType = activeType === 'all' || item.dataset.type === activeType;
      const matchQuery = !query || (item.dataset.title ?? '').includes(query);
      item.style.display = matchType && matchQuery ? '' : 'none';
    });
  }
</script>
