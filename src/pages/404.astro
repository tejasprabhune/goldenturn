---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - the golden turn" description="Page not found.">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6">
    <p class="font-display italic text-accent text-8xl font-semibold leading-none mb-4">404</p>
    <p class="text-heading text-xl mb-8">Page not found.</p>
    <a href="/" class="text-accent hover:text-accent/70 font-body text-sm underline underline-offset-4">
      Back to home
    </a>
  </div>
</BaseLayout>
