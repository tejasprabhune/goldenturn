---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit a Recording | the golden turn">
  <div class="max-w-2xl mx-auto px-6 pt-12 pb-24">
    <h1 class="font-display italic text-heading text-4xl mb-2">Submit a Recording</h1>
    <p class="font-sans text-sm text-ink/50 mb-1">Recordings appear in search immediately.</p>
    <p class="font-sans text-xs text-ink/35 mb-10">
      <a href="/recordings" class="hover:text-ink transition-colors">Back to recordings</a>
    </p>

    <form id="submission-form" novalidate>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Round title</label>
        <input type="text" name="title" placeholder="Finals - Cal MR vs Rice AL"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Link</label>
        <p class="form-hint">Dropbox, YouTube, or Vimeo URL</p>
        <input type="text" name="link" placeholder="https://..."
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Resolution</label>
        <input type="text" name="resolution" placeholder="The USFG should..."
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Aff</label>
        <p class="form-hint">Describe aff strategy</p>
        <input type="text" name="aff" placeholder="topical (war, econ)"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Neg</label>
        <p class="form-hint">Lead with N-off, e.g. 2-off</p>
        <input type="text" name="neg" placeholder="2-off (framework-t, orientalism)"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Tags</label>
        <p class="form-hint">Comma-separated, each starting with #</p>
        <input type="text" name="tags" placeholder="#topicality, #mlm"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Decision</label>
        <p class="form-hint">e.g. 3-0 Aff or 2-1 Neg</p>
        <input type="text" name="decision" placeholder="3-0 Aff"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-7">
        <label class="block font-sans text-sm text-ink mb-0.5">Year</label>
        <p class="form-hint">e.g. 2020-21</p>
        <input type="text" name="year" placeholder="2020-21"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="mb-10">
        <label class="block font-sans text-sm text-ink mb-0.5">Tournament</label>
        <input type="text" name="tournament" placeholder="NPDA"
          class="form-input" />
        <p class="validation-hint"></p>
      </div>

      <div class="flex items-center gap-4">
        <button type="submit" id="submit-btn" class="submit-btn">
          Submit recording
        </button>
        <p id="submit-error" class="font-sans text-xs text-ink/50 hidden"></p>
      </div>

    </form>

    <div id="success-state" class="hidden pt-2">
      <p class="font-sans text-sm text-ink/70 mb-3">Recording submitted and live in search.</p>
      <a href="/recordings" class="font-sans text-sm text-heading hover:underline transition-colors">Back to recordings</a>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .form-input {
    display: block;
    width: 100%;
    border: 1px solid rgba(26,26,26,0.15);
    border-radius: 0.5rem;
    background: white;
    padding: 0.625rem 0.875rem;
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.875rem;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.12s, box-shadow 0.12s;
  }
  .form-input::placeholder {
    color: rgba(26,26,26,0.28);
  }
  .form-input:focus {
    border-color: rgba(26,26,26,0.35);
    box-shadow: 0 0 0 2px rgba(26,26,26,0.07);
  }

  .form-hint {
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.75rem;
    color: #1a1a1a;
    opacity: 0.38;
    margin-bottom: 0.375rem;
    margin-top: 0;
  }

  .validation-hint {
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.75rem;
    color: #1a1a1a;
    opacity: 0.45;
    margin-top: 0.25rem;
    min-height: 1rem;
  }

  .submit-btn {
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    background: #2f4858;
    color: #fcefef;
    border: none;
    border-radius: 0.375rem;
    padding: 0.625rem 1.25rem;
    cursor: pointer;
    transition: opacity 0.12s;
  }
  .submit-btn:hover {
    opacity: 0.88;
  }
  .submit-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }
</style>

<script>
  import { algoliasearch } from 'algoliasearch';

  const APP_ID = 'CS1MDMNJTO';
  const WRITE_KEY = '24934eda81fbfc13e8875adc571d8043';
  const INDEX_NAME = 'all_rounds';

  const client = algoliasearch(APP_ID, WRITE_KEY);

  const form = document.getElementById('submission-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitError = document.getElementById('submit-error') as HTMLParagraphElement;
  const successState = document.getElementById('success-state') as HTMLDivElement;

  function getField(name: string): HTMLInputElement {
    return form.querySelector(`[name="${name}"]`) as HTMLInputElement;
  }

  function getHint(name: string): HTMLParagraphElement {
    return getField(name).nextElementSibling as HTMLParagraphElement;
  }

  const validators: Record<string, (v: string) => string | null> = {
    tags: (v) => {
      if (!v.trim()) return null;
      const bad = v.split(',').map(t => t.trim()).filter(t => t && !t.startsWith('#'));
      return bad.length ? 'Each tag should start with #' : null;
    },
    decision: (v) => {
      if (!v.trim()) return null;
      return /^\d+-\d+ (Aff|Neg)$/.test(v.trim()) ? null : 'Expected: 3-0 Aff or 2-1 Neg';
    },
    year: (v) => {
      if (!v.trim()) return null;
      return /^\d{4}-\d{2}$/.test(v.trim()) ? null : 'Expected: 2020-21';
    },
    neg: (v) => {
      if (!v.trim()) return null;
      return /\d+-off|off/i.test(v) ? null : 'Consider leading with N-off, e.g. 2-off (da, cp)';
    },
  };

  for (const [name, validate] of Object.entries(validators)) {
    const field = getField(name);
    const hint = getHint(name);
    field.addEventListener('blur', () => { hint.textContent = validate(field.value) ?? ''; });
    field.addEventListener('input', () => { hint.textContent = validate(field.value) ?? ''; });
  }

  function computeAffType(tags: string[]): string {
    if (tags.some(t => t === '#k-aff')) return 'k-aff';
    if (tags.some(t => t === '#performance')) return 'performance';
    return 'topical';
  }

  function computeNegStrategyCount(neg: string): number | null {
    const m = neg.match(/(\d+)-off/i);
    return m ? parseInt(m[1], 10) : null;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const title      = getField('title').value.trim();
    const link       = getField('link').value.trim();
    const resolution = getField('resolution').value.trim();
    const aff        = getField('aff').value.trim();
    const neg        = getField('neg').value.trim();
    const tagsRaw    = getField('tags').value.trim();
    const decision   = getField('decision').value.trim();
    const year       = getField('year').value.trim();
    const tournament = getField('tournament').value.trim();

    const tags = tagsRaw
      ? tagsRaw.split(',').map(t => t.trim()).filter(t => t.startsWith('#'))
      : [];

    const record = {
      objectID: `sub-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
      title, link, resolution, aff, neg,
      _tags: tags,
      searchable_tags: tags,
      decision, year, tournament,
      teams: [],
      aff_type: computeAffType(tags),
      neg_strategy_count: computeNegStrategyCount(neg),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    submitError.classList.add('hidden');

    try {
      await client.saveObject({ indexName: INDEX_NAME, body: record });
      form.classList.add('hidden');
      successState.classList.remove('hidden');
    } catch (err) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit recording';
      submitError.textContent = 'Submission failed. Please try again.';
      submitError.classList.remove('hidden');
      console.error(err);
    }
  });
</script>
