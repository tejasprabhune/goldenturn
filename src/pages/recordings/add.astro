---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit a Recording | the golden turn">
  <div class="max-w-2xl mx-auto px-6 pt-16 pb-24">
    <h1 class="font-display italic text-heading text-5xl leading-tight mb-3">Submit a Recording</h1>
    <p class="font-sans text-ink/60 text-sm mb-1">
      Recordings go directly into the index and appear in search immediately.
    </p>
    <p class="font-sans text-ink/40 text-xs mb-10">
      <a href="/recordings" class="text-heading hover:underline transition-colors">Back to recordings</a>
    </p>

    <form id="submission-form" novalidate class="space-y-0">

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Round title</label>
        <input type="text" name="title" placeholder="Finals - Cal MR vs Rice AL"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Link</label>
        <p class="font-sans text-xs text-ink/35 mb-1">Dropbox, YouTube, or Vimeo URL</p>
        <input type="text" name="link" placeholder="https://..."
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Resolution</label>
        <input type="text" name="resolution" placeholder="The USFG should..."
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Aff</label>
        <p class="font-sans text-xs text-ink/35 mb-1">Describe aff strategy</p>
        <input type="text" name="aff" placeholder="topical (war, econ)"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Neg</label>
        <p class="font-sans text-xs text-ink/35 mb-1">Start with N-off, e.g. 2-off</p>
        <input type="text" name="neg" placeholder="2-off (framework-t, orientalism)"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Tags</label>
        <p class="font-sans text-xs text-ink/35 mb-1">Must start with #, comma-separated</p>
        <input type="text" name="tags" placeholder="#topicality, #mlm"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Decision</label>
        <p class="font-sans text-xs text-ink/35 mb-1">Format: N-N Aff/Neg</p>
        <input type="text" name="decision" placeholder="3-0 Aff"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-6">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Year</label>
        <p class="font-sans text-xs text-ink/35 mb-1">Format: YYYY-YY</p>
        <input type="text" name="year" placeholder="2020-21"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="mb-8">
        <label class="block font-sans text-sm font-medium text-ink mb-1">Tournament</label>
        <input type="text" name="tournament" placeholder="NPDA"
          class="w-full border border-ink/15 rounded-lg px-3 py-2.5 font-sans text-sm text-ink placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" />
        <p class="validation-hint font-sans text-xs text-ink/50 mt-1 hidden"></p>
      </div>

      <div class="flex items-center gap-4">
        <button type="submit" id="submit-btn"
          class="font-sans text-sm text-heading border border-heading/40 rounded px-5 py-2.5 hover:border-heading hover:bg-heading hover:text-paper transition-colors">
          Submit recording
        </button>
        <p id="submit-error" class="font-sans text-xs text-ink/50 hidden"></p>
      </div>
    </form>

    <div id="success-state" class="hidden pt-4">
      <p class="font-sans text-sm text-ink/70 mb-3">Recording submitted. It will appear in search shortly.</p>
      <a href="/recordings" class="font-sans text-sm text-heading hover:underline transition-colors">Back to recordings</a>
    </div>
  </div>
</BaseLayout>

<script>
  import { algoliasearch } from 'algoliasearch';

  const APP_ID = 'CS1MDMNJTO';
  const WRITE_KEY = '24934eda81fbfc13e8875adc571d8043';
  const INDEX_NAME = 'all_rounds';

  const client = algoliasearch(APP_ID, WRITE_KEY);

  const form = document.getElementById('submission-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitError = document.getElementById('submit-error') as HTMLParagraphElement;
  const successState = document.getElementById('success-state') as HTMLDivElement;

  function getField(name: string): HTMLInputElement {
    return form.querySelector(`[name="${name}"]`) as HTMLInputElement;
  }

  function getHint(name: string): HTMLParagraphElement {
    return getField(name).nextElementSibling as HTMLParagraphElement;
  }

  function showHint(name: string, msg: string) {
    const hint = getHint(name);
    hint.textContent = msg;
    hint.classList.remove('hidden');
  }

  function clearHint(name: string) {
    const hint = getHint(name);
    hint.textContent = '';
    hint.classList.add('hidden');
  }

  const validators: Record<string, (v: string) => string | null> = {
    tags: (v) => {
      if (!v.trim()) return null;
      const bad = v.split(',').map(t => t.trim()).filter(t => t && !t.startsWith('#'));
      return bad.length > 0 ? 'Tags should start with #' : null;
    },
    decision: (v) => {
      if (!v.trim()) return null;
      return /^\d+-\d+ (Aff|Neg)$/.test(v.trim()) ? null : 'Expected format: 3-0 Aff or 2-1 Neg';
    },
    year: (v) => {
      if (!v.trim()) return null;
      return /^\d{4}-\d{2}$/.test(v.trim()) ? null : 'Expected format: 2020-21';
    },
    neg: (v) => {
      if (!v.trim()) return null;
      return /\d+-off|off/i.test(v) ? null : 'Consider leading with N-off, e.g. 2-off (da, cp)';
    },
  };

  for (const [name, validate] of Object.entries(validators)) {
    const field = getField(name);
    field.addEventListener('blur', () => {
      const msg = validate(field.value);
      msg ? showHint(name, msg) : clearHint(name);
    });
    field.addEventListener('input', () => {
      const msg = validate(field.value);
      msg ? showHint(name, msg) : clearHint(name);
    });
  }

  function computeAffType(tags: string[]): string {
    if (tags.some(t => t === '#k-aff')) return 'k-aff';
    if (tags.some(t => t === '#performance')) return 'performance';
    return 'topical';
  }

  function computeNegStrategyCount(neg: string): number | null {
    const m = neg.match(/(\d+)-off/i);
    return m ? parseInt(m[1], 10) : null;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const title = getField('title').value.trim();
    const link = getField('link').value.trim();
    const resolution = getField('resolution').value.trim();
    const aff = getField('aff').value.trim();
    const neg = getField('neg').value.trim();
    const tagsRaw = getField('tags').value.trim();
    const decision = getField('decision').value.trim();
    const year = getField('year').value.trim();
    const tournament = getField('tournament').value.trim();

    const tags = tagsRaw
      ? tagsRaw.split(',').map(t => t.trim()).filter(t => t.startsWith('#'))
      : [];

    const record = {
      objectID: `sub-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
      title,
      link,
      resolution,
      aff,
      neg,
      _tags: tags,
      searchable_tags: tags,
      decision,
      year,
      tournament,
      teams: [],
      aff_type: computeAffType(tags),
      neg_strategy_count: computeNegStrategyCount(neg),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    submitError.classList.add('hidden');

    try {
      await client.saveObject({ indexName: INDEX_NAME, body: record });
      form.classList.add('hidden');
      successState.classList.remove('hidden');
    } catch (err) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit recording';
      submitError.textContent = 'Submission failed. Please try again.';
      submitError.classList.remove('hidden');
      console.error(err);
    }
  });
</script>
