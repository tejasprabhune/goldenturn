---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="the golden turn"
  description="An open resource for college parliamentary debate."
>
  <div class="home-block">
    <h1 class="home-wordmark">the golden turn</h1>
    <div class="home-rule" aria-hidden="true"></div>
    <p class="home-desc">
      an open resource for college parliamentary debate.
      curriculum, recordings, files, playbooks, and a reference for the Ks,
      written and collected by debaters.
    </p>
    <nav aria-label="Sections" class="home-nav">
      <a href="/curriculum">curriculum</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/recordings">recordings</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/k">ks</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/files">files</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/playbooks">playbooks</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/lectures">lectures</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .home-block {
    padding-top: clamp(2.5rem, 14vh, 6rem);
    padding-left: clamp(1.75rem, 18vw, 9rem);
    padding-right: 2rem;
    padding-bottom: 4rem;
    max-width: 44rem;
  }

  .home-wordmark {
    font-family: 'swear-display', Georgia, serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(2.75rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: #2f4858;
    margin: 0 0 0.875rem;
  }

  .home-rule {
    width: 88px;
    height: 3px;
    background: #ced530;
    margin-bottom: 1.625rem;
  }

  .home-desc {
    font-family: 'freight-text-pro', 'neue-haas-unica', Georgia, serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #1a1a1a;
    opacity: 0.72;
    margin: 0 0 1.75rem;
    max-width: 32rem;
  }

  .home-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.6rem;
  }

  .home-nav a {
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #1a1a1a;
    opacity: 0.48;
    text-decoration: none;
    transition: opacity 0.15s, color 0.15s;
  }

  .home-nav a:hover {
    opacity: 1;
    color: #2f4858;
  }

  .home-nav span {
    color: #1a1a1a;
    opacity: 0.2;
    font-size: 0.7rem;
  }

  @media (max-width: 640px) {
    .home-block {
      padding-left: 1.75rem;
      padding-top: 2.5rem;
    }

    .home-wordmark {
      font-size: clamp(2.5rem, 10vw, 3rem);
    }
  }
</style>
