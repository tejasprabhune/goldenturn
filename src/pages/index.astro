---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="the golden turn"
  description="An open resource for college parliamentary debate."
  minimalNav={true}
>
  <div class="home">
    <div class="home__text">
      <div class="home__text-inner">
        <h1 class="home__wordmark">the golden turn</h1>
        <p class="home__tagline">An open resource for college parliamentary debate.</p>
        <nav aria-label="Sections" class="home__nav">
          <a href="/curriculum">curriculum</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/recordings">recordings</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/k">ks</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/files">files</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/playbooks">playbooks</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/lectures">lectures</a>
        </nav>
      </div>
    </div>

    <div class="home__image" aria-hidden="true">
      <img
        src="/images/home-hero.png"
        alt=""
        width="1024"
        height="559"
      />
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    min-height: calc(100vh - 3.5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr;
  }

  .home__text {
    display: flex;
    align-items: flex-end;
    padding: clamp(2rem, 6vw, 5rem) clamp(1.5rem, 5vw, 5rem);
  }

  .home__text-inner {
    max-width: 36rem;
  }

  .home__wordmark {
    font-family: 'swear-display', Georgia, serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(3.5rem, 7vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: #2f4858;
    margin: 0 0 clamp(1.25rem, 2.5vh, 2rem);
  }

  .home__tagline {
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #1a1a1a;
    opacity: 0.42;
    margin: 0 0 clamp(1.5rem, 3vh, 2.25rem);
    max-width: 24rem;
  }

  .home__nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.6rem;
  }

  .home__nav a {
    font-family: 'neue-haas-unica', system-ui, sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: #1a1a1a;
    opacity: 0.45;
    text-decoration: none;
    transition: opacity 0.15s, color 0.15s;
  }

  .home__nav a:hover {
    opacity: 1;
    color: #ced530;
  }

  .home__nav span {
    color: #1a1a1a;
    opacity: 0.18;
    font-size: 0.7rem;
    line-height: 1;
  }

  .home__image {
    position: relative;
    overflow: hidden;
  }

  .home__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .home {
      grid-template-columns: 1fr;
      grid-template-rows: 44vh 1fr;
    }

    .home__image {
      order: -1;
    }

    .home__image img {
      object-position: center 40%;
    }

    .home__text {
      align-items: flex-start;
      padding: 2rem 1.5rem 3rem;
    }

    .home__wordmark {
      font-size: clamp(3rem, 12vw, 5rem);
    }
  }
</style>
